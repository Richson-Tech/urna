# Copy this file to `.env` and fill in your own values.

# Path to the SQLite database. Prisma resolves it relative to the
# schema.prisma file, so `file:./dev.db` ends up at prisma/dev.db.
DATABASE_URL="file:./dev.db"

# 32+ character random string. In development anything works; in
# production generate one with:  openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-characters"

# Public URL where the app is reachable. Used for the share links
# shown on election pages and for the QR codes. Leave as localhost
# for local dev; set to your real domain in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
